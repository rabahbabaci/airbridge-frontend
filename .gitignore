#env
.env
.env.*
# Production env file is committed so Vercel and TestFlight archives
# always see the right API URLs regardless of any local .env.local
# a contributor may have set up for dev work. .env.local remains ignored
# via the *.local rule below.
!.env.production

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env

# Capacitor native build artifacts
ios/App/Pods/
ios/App/build/
ios/App/App.xcworkspace/xcuserdata/
android/.gradle/
android/build/
android/app/build/